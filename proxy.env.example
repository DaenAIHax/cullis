# ═══════════════════════════════════════════════════════════════════════════════
# Cullis MCP Proxy — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════════════
#
# Copy this file to proxy.env and fill in the values.
# Variables marked [REQUIRED] must be set before starting the proxy.
# Variables marked [PRODUCTION] must be changed from defaults before go-live.
#

# ─── Environment ─────────────────────────────────────────────────────────────

# "development" relaxes some checks (admin secret default allowed, etc).
# "production" rejects insecure defaults at boot.
MCP_PROXY_ENVIRONMENT=development

# ─── Security ────────────────────────────────────────────────────────────────

# [REQUIRED] [PRODUCTION] Admin secret for the proxy dashboard and admin API.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_PROXY_ADMIN_SECRET=change-me-in-production

# [PRODUCTION] Persistent HMAC key for the proxy dashboard cookies.
# Without this, admin sessions are invalidated on every proxy restart
# because a random key is generated per-process.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
MCP_PROXY_DASHBOARD_SIGNING_KEY=

# ─── Broker uplink ───────────────────────────────────────────────────────────

# [REQUIRED] URL of the Cullis broker. Use HTTPS in production; HTTP only
# when the proxy and broker are on the same Docker network (dev/e2e).
# Examples:
#   http://broker:8000                    # same docker-compose network (dev)
#   https://broker.cullis.example.com     # remote production broker
MCP_PROXY_BROKER_URL=http://broker:8000

# If the broker's TLS cert is signed by a non-public CA (corporate root or
# Let's Encrypt staging), mount that CA in the container and point this
# file at it. Leave empty to use the system bundle (Let's Encrypt public).
# Path is INSIDE the container — see docker-compose.proxy.yml for mount.
# Example: /certs/corporate-ca.pem
MCP_PROXY_BROKER_CA_BUNDLE=

# JWKS endpoint for validating broker-issued JWTs (used by proxy ingress).
# In production this should match BROKER_URL + /.well-known/jwks.json.
MCP_PROXY_BROKER_JWKS_URL=http://broker:8000/.well-known/jwks.json

# ─── Proxy identity ──────────────────────────────────────────────────────────

# Public URL where the proxy itself is reachable. Used for DPoP HTU
# validation on the ingress endpoints — must match how internal agents
# address the proxy.
MCP_PROXY_PROXY_PUBLIC_URL=http://localhost:9100

# PDP webhook URL — the broker calls this to ask the proxy for policy
# decisions. Must be reachable from the broker container/host.
# On the same Docker network: http://mcp-proxy:9100/pdp/policy
# On a remote proxy: https://proxy.myorg.example.com/pdp/policy
MCP_PROXY_PDP_URL=http://mcp-proxy:9100/pdp/policy

# CORS — comma-separated origins allowed to call the proxy dashboard.
# Empty = no CORS middleware (fail-safe).
MCP_PROXY_ALLOWED_ORIGINS=

# ─── Network ─────────────────────────────────────────────────────────────────

# Host port where the proxy listens. Internal container port is always 9100.
MCP_PROXY_PORT=9100

# Docker network mode:
#   shared    — proxy joins the broker's docker-compose network (same host)
#   standalone — proxy runs on its own network and talks to a remote broker
# Used by deploy_proxy.sh to pick the right compose override.
MCP_PROXY_NETWORK_MODE=shared

# ─── Vault (optional) ────────────────────────────────────────────────────────

# If the proxy should store agent-signing secrets in Vault instead of disk.
# MCP_PROXY_SECRET_BACKEND=vault
# MCP_PROXY_VAULT_ADDR=https://vault.myorg.example.com:8200
# MCP_PROXY_VAULT_TOKEN=   # scoped token, NOT the root token
